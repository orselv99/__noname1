# Database Connection Strings
# For Auth Service (users table)
DB_DSN_AUTH=host=localhost user=postgres password=postgres dbname=fiery_auth port=5432 sslmode=disable

# For Index Service (documents table + pgvector)
DB_DSN_INDEX=host=localhost user=postgres password=postgres dbname=fiery_index port=5432 sslmode=disable

# JWT Secret (Used by Auth Service and Gateway)
# WARNING: Change this in production!
JWT_SECRET=my_super_secure_secret_key_change_me

# Master Key for Encryption (Used by Index Service)
# Currently hardcoded in server/common/crypto/crypto.go for development.
# In production, this should be loaded from environment variable MASTER_KEY.
MASTER_KEY=fiery-horizon-super-secret-master-key-2026

# Service Ports (Currently hardcoded in main.go)
# Auth: 50051
# Index: 50052
# Signaling: 50053
# Gateway: 8080
